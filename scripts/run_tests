#!/bin/bash
# Test runner script for DWD Weather component

set -e

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
PROJECT_DIR="$SCRIPT_DIR"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Functions
print_header() {
    echo -e "${BLUE}======================================${NC}"
    echo -e "${BLUE}$1${NC}"
    echo -e "${BLUE}======================================${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
}

print_info() {
    echo -e "${YELLOW}ℹ $1${NC}"
}

# Main script
case "${1:-all}" in
    all)
        print_header "Running All Tests"
        cd "$PROJECT_DIR"
        pytest --cov=custom_components/dwd_weather --cov-report=html --cov-report=term-missing
        print_success "All tests passed!"
        ;;

    unit)
        print_header "Running Unit Tests"
        cd "$PROJECT_DIR"
        pytest tests/test_connector.py tests/test_config_flow.py -v
        print_success "Unit tests passed!"
        ;;

    integration)
        print_header "Running Integration Tests"
        cd "$PROJECT_DIR"
        pytest tests/test__init.py -v
        print_success "Integration tests passed!"
        ;;

    quick)
        print_header "Running Quick Test Suite"
        cd "$PROJECT_DIR"
        pytest -x --tb=short
        print_success "Quick tests passed!"
        ;;

    coverage)
        print_header "Running Tests with Coverage Report"
        cd "$PROJECT_DIR"
        pytest --cov=custom_components/dwd_weather --cov-report=html --cov-report=term-missing
        print_success "Coverage report generated in htmlcov/index.html"
        if command -v xdg-open &> /dev/null; then
            xdg-open htmlcov/index.html
        elif command -v open &> /dev/null; then
            open htmlcov/index.html
        fi
        ;;

    watch)
        print_header "Running Tests in Watch Mode"
        cd "$PROJECT_DIR"
        print_info "Watching for changes... (requires pytest-watch)"
        ptw
        ;;

    config)
        print_header "Running Config Flow Tests"
        cd "$PROJECT_DIR"
        pytest tests/test_config_flow.py -v
        print_success "Config flow tests passed!"
        ;;

    entities)
        print_header "Running Entity Tests"
        cd "$PROJECT_DIR"
        pytest tests/test_weather_entity.py tests/test_sensor_entity.py -v
        print_success "Entity tests passed!"
        ;;

    verbose)
        print_header "Running All Tests (Verbose)"
        cd "$PROJECT_DIR"
        pytest -v --tb=long
        print_success "All tests passed!"
        ;;

    lint)
        print_header "Running Linters"
        cd "$PROJECT_DIR"
        if command -v ruff &> /dev/null; then
            ruff check custom_components/dwd_weather tests
            print_success "Ruff linting passed!"
        else
            print_error "Ruff not installed"
        fi
        ;;

    format)
        print_header "Formatting Code"
        cd "$PROJECT_DIR"
        if command -v ruff &> /dev/null; then
            ruff format custom_components/dwd_weather tests
            print_success "Code formatted!"
        else
            print_error "Ruff not installed"
        fi
        ;;

    specific)
        if [ -z "$2" ]; then
            print_error "Please provide test path or name"
            echo "Usage: $0 specific <test_path_or_name>"
            exit 1
        fi
        print_header "Running Specific Test: $2"
        cd "$PROJECT_DIR"
        pytest "$2" -v
        print_success "Test passed!"
        ;;

    help|--help|-h)
        cat << EOF
DWD Weather Test Runner

Usage: $0 [command]

Commands:
    all         Run all tests with coverage (default)
    unit        Run unit tests only
    integration Run integration tests only
    quick       Run quick test suite (fail on first error)
    coverage    Run tests and open HTML coverage report
    watch       Run tests in watch mode (requires pytest-watch)
    config      Run configuration flow tests
    entities    Run entity tests (weather & sensor)
    verbose     Run all tests with verbose output
    lint        Run code linters
    format      Format code with ruff
    specific    Run specific test (e.g. "$0 specific tests/test_config_flow.py")
    help        Show this help message

Examples:
    $0                                    # Run all tests
    $0 coverage                          # Generate coverage report
    $0 specific tests/test_config_flow.py # Run specific test file
    $0 specific test_config_flow_user_station # Run specific test function

EOF
        ;;

    *)
        print_error "Unknown command: $1"
        echo "Run '$0 help' for usage information"
        exit 1
        ;;
esac
